    bedrock --> model["Foundation Model"]
    bedrock --> kb["Bedrock Knowledge Base"]
    bedrock --> guardrails["Bedrock Guardrails"]
    bedrock --> agent["Agent / AgentCore Pattern"]

    kb --> s3["Approved Documents in S3"]
